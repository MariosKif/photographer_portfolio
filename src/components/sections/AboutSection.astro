---
const facts = [
  { number: 6, icon: 'ion-ios-timer-outline', title: 'Years' },
  { number: 53, icon: 'ion-ios-photos-outline', title: 'Items' },
  { number: 355, icon: 'ion-ios-world-outline', title: 'Clients' },
  { number: 9800, icon: 'ion-ios-people', title: 'Followers' },
];
---
<div class="section relative overflow-hidden bg-black" id="about">
  <div class="section-title-vertical"><span>About</span></div>

  <div class="relative z-[5] flex flex-wrap">
    <!-- left: about image -->
    <div class="w-full lg:w-1/2 !p-0 !m-0">
      <div class="overlay overlay-inverse-dark-35 relative">
        <div class="relative h-screen">
          <div class="h-screen bg-cover bg-center bg-no-repeat lg:absolute lg:w-[50vw] lg:h-auto lg:top-0 lg:bottom-0 sm:min-h-[350px]" style="background-image: url('/img/about/DSC_6368 copy.jpg')"></div>
        </div>
      </div>
    </div>

    <!-- right: about content slider -->
    <div class="w-full lg:w-1/2 !p-0 !m-0">
      <div class="about-swiper relative w-full h-auto">
        <div class="swiper about-content-swiper">
          <div class="swiper-wrapper">
            <!-- slide 1: about text -->
            <div class="swiper-slide">
              <div class="relative h-screen">
                <div class="absolute w-full h-full left-0 top-0 flex items-center justify-center bg-black">
                  <div class="relative w-full px-[25px] text-center 2xl:px-[150px] xl:px-[25px] lg:px-[20px]">
                    <h2 class="font-oswald text-[35px] font-normal uppercase tracking-wide text-white leading-[1.25] pb-[35px] spacer-line-vertical-light">About</h2>
                    <p class="text-white mt-[53px] 2xl:mt-[101px] lg:mt-[101px] lg:px-[35px]">
                      Pro Photo GR ή αλλιώς Ιωάννης Μαστροσταμάτης. Επαγγελματίας φωτογράφος με 5ετή εμπειρία στη φωτογραφία και τη βιντεογραφία, με έμφαση στο καλλιτεχνικό πορτρέτο, στη διαφημιστική παραγωγή και στη φωτογράφιση προϊόντων. Διαθέτω πρακτική εμπειρία σε studio setup, φωτισμό, επεξεργασία εικόνας και παραγωγή οπτικού περιεχομένου για events, καμπάνιες, social media, καταλόγους και e-shop. Συνδυάζω δημιουργική ματιά με συνέπεια στην εκτέλεση και στόχο την αποτύπωση εικόνων που υπηρετούν τόσο την αισθητική όσο και την εμπορική ανάγκη του πελάτη.
                    </p>
                  </div>
                </div>
              </div>
            </div>

            <!-- slide 2: facts -->
            <div class="swiper-slide">
              <div class="relative h-screen">
                <div class="absolute w-full h-full left-0 top-0 flex items-center justify-center bg-black">
                  <div class="relative w-full px-[25px] text-center lg:px-[20px]">
                    <h3 class="font-oswald text-[23px] font-normal uppercase tracking-wide text-white lg:text-[18px]">The Facts</h3>
                    <div class="p-0 mt-[37px] -mx-[15px] grid grid-cols-2 xl:grid-cols-4 gap-4 lg:mt-[40px] lg:mx-0">
                      {facts.map((fact, i) => (
                        <div class={`text-center ${i >= 2 ? 'mt-0 lg:mt-[40px] xl:mt-0' : ''}`}>
                          <div class="facts-counter-number font-oswald text-[25px] font-normal uppercase -tracking-[0.04em] leading-[1.3] text-center text-white lg:text-[18px]" data-target={fact.number}>{fact.number}</div>
                          <div class="text-white text-center uppercase">
                            <i class={`${fact.icon} block text-[30px] text-center text-[#5f5f5f] my-[10px] lg:text-[20px] lg:my-[14px]`}></i>
                            <span class="text-[11px] tracking-wide font-bold">{fact.title}</span>
                          </div>
                        </div>
                      ))}
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
          <div class="swiper-button-prev"></div>
          <div class="swiper-button-next"></div>
        </div>
      </div>
    </div>
  </div>
</div>
